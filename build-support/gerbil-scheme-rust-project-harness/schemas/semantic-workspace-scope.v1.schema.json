{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-workspace-scope.v1.schema.json",
  "title": "Semantic Workspace Scope v1",
  "description": "Provider-resolved package-manager workspace membership used for pre-rank search candidate admission.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "schemaVersion", "workspaceId", "languageId", "providerId", "packageManager", "sourceExtensions", "discoveryRoot", "anchors", "packages", "admittedRoots", "fingerprint"],
  "properties": {
    "schemaId": {"const": "agent.semantic-protocols.semantic-workspace-scope"},
    "schemaVersion": {"const": "1"},
    "workspaceId": {"type": "string", "minLength": 1},
    "languageId": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "providerId": {"type": "string", "minLength": 1},
    "packageManager": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "sourceExtensions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^\\.[A-Za-z0-9][A-Za-z0-9._+-]*$"}},
    "discoveryRoot": {"type": "string", "minLength": 1},
    "anchors": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/anchor"}},
    "packages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/package"}},
    "admittedRoots": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "$defs": {
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "name", "root", "manifestPath", "languageId"],
      "properties": {
        "packageId": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "root": {"type": "string", "minLength": 1},
        "manifestPath": {"type": "string", "minLength": 1},
        "languageId": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
      }
    }
  }
}
